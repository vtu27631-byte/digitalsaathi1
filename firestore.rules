rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprint for User
    function isValidUser(data) {
      let fields = ['name', 'language', 'riskLevel', 'createdAt', 'updatedAt', 'completedScenarios', 'currentScenarioId'];
      return data.keys().hasAll(fields)
        && data.keys().size() == 7
        && data.name is string && data.name.size() <= 100
        && data.language in ['english', 'hindi', 'tamil', 'telugu', 'kannada']
        && data.riskLevel in ['Beginner', 'Learning', 'Safe User']
        && data.completedScenarios is list
        && data.completedScenarios.size() <= 100
        && (data.currentScenarioId == null || (data.currentScenarioId is string && data.currentScenarioId.size() <= 100))
        && data.updatedAt == request.time;
    }

    // User Profiles
    match /users/{userId} {
      // Identity Poisoning Guard
      allow get: if isOwner(userId) && isValidId(userId);
      
      // Secure List Query (Implicitly Denied by omission, explicitly here)
      allow list: if false;

      // Create Profile
      allow create: if isOwner(userId)
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().createdAt == request.time;

      // Update Profile / Progress
      allow update: if isOwner(userId)
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().createdAt == existing().createdAt
        && (
          // Action: Any progress or profile update
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'language', 'riskLevel', 'completedScenarios', 'currentScenarioId', 'updatedAt'])
        );

      // Delete Profile
      allow delete: if false; // Administrative or deletion flow not implemented in client
    }
  }
}
